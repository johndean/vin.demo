# VIN Demo — environment template. Copy to .env and fill in. NEVER commit .env.

# ── Required ──────────────────────────────────────────────────────────────────
# Railway Postgres (pgvector). External/public connection string.
DATABASE_URL=postgresql://user:pass@host.proxy.rlwy.net:PORT/railway
# Claude (claude-opus-4-8) — interpret / explain / node-selection.
ANTHROPIC_API_KEY=sk-ant-...
# Voyage (voyage-3) embeddings.
VOYAGE_API_KEY=pa-...
# Set after `npm run seed` prints it — scopes retrieval/nav to PO.vin.
PO_VIN_PRODUCT_ID=

# ── PO.vin demo target (per-persona logins) ──────────────────────────────────
PO_VIN_URL=https://po.vin
PO_VIN_ROLE=admin                 # which persona to drive as (admin|owner|manager|...)
# PO_VIN_MODE=read-only           # execution mode (default read-only; never change for demos without authorization)
PO_VIN_ADMIN_USER=
PO_VIN_ADMIN_PASS=
# ...one USER/PASS pair per role you demo as (OWNER/MANAGER/ACCOUNTING/EMPLOYEE)

# ── Hosted engine (apps/engine) — auth ───────────────────────────────────────
# Secret used to verify the signed session token on /session/stream (HMAC). REQUIRED for the
# engine AND the web console — use the SAME value on both Railway services. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string

# ── Desktop thin client (apps/desktop) — dev overrides ────────────────────────
# The packaged app needs NONE of these (it defaults to the hosted web + engine). For local dev:
# VIN_DEMO_WEB_URL=http://localhost:3000        # web SSOT (auth + console data); default https://demofor.vin
# VIN_DEMO_ENGINE_URL=http://localhost:8080     # hosted engine stream; default https://engine.demofor.vin
# VIN_DEMO_LOCAL_ENGINE=1                        # dev-only: spawn the engine locally instead of streaming
#                                                # (requires VIN_DEMO_ENGINE_URL to be UNSET)

# ── Optional ──────────────────────────────────────────────────────────────────
# EMBEDDING_PROVIDER=voyage        # voyage (default) | gemini | vertex (swaps; 768-dim needs a dim migration)
# Opt-in tracing — LangGraph auto-emits to LangSmith when these are set (no code change):
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2-...
# LANGCHAIN_PROJECT=vin-demo
