# Seeded operator account(s) for the gated console login.
# Set these as Railway environment variables in production (never commit real secrets).
ADMIN_EMAIL=admin@demofor.vin
ADMIN_PASSWORD=change-me

# Optional: extra seeded users as a JSON array of {email,password,role}.
# SEED_USERS=[{"email":"manager@demofor.vin","password":"...","role":"manager"}]

# Secret used to SIGN the session cookie (HMAC). REQUIRED. Must be the SAME value on the web
# service and the hosted engine service so the engine can verify tokens the web issues.
# Generate a strong random value, e.g.  openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string
